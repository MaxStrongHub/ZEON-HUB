            ToggleBtn.BackgroundColor3 = Color3.fromRGB(60, 45, 95)
            StatusText.Text = "STATUS: IDLE"
            StatusIcon.TextColor3 = Color3.fromRGB(150, 150, 150)
            StatusText.TextColor3 = Color3.fromRGB(180, 180, 180)
            TargetText.Text = "🎯 TARGET: -"
            FlyEnabled = false
            if BodyVelocity.Parent then
                BodyVelocity.Velocity = Vector3.new(0, 0, 0)
            end
        end
    end)
    
    ESPToggle.MouseButton1Click:Connect(function()
        Settings.ESPEnabled = not Settings.ESPEnabled
        if Settings.ESPEnabled then
            ESPToggle.Text = "👁️ ESP: ON"
            ESPToggle.TextColor3 = Color3.fromRGB(100, 255, 100)
            ScanForFruits()
        else
            ESPToggle.Text = "👁️ ESP: OFF"
            ESPToggle.TextColor3 = Color3.fromRGB(200, 200, 200)
            ClearAllESP()
        end
    end)
    
    StoreToggle.MouseButton1Click:Connect(function()
        Settings.AutoStore = not Settings.AutoStore
        StoreToggle.Text = Settings.AutoStore and "📦 AUTO STORE: ON" or "📦 AUTO STORE: OFF"
        StoreToggle.TextColor3 = Settings.AutoStore and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(200, 200, 200)
    end)
    
    -- Slider Drag Function
    local draggingSlider = false
    SpeedSliderBtn.MouseButton1Down:Connect(function()
        draggingSlider = true
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
            local barPos = SpeedSliderBar.AbsolutePosition.X
            local barWidth = SpeedSliderBar.AbsoluteSize.X
            local mouseX = input.Position.X
            local percent = math.clamp((mouseX - barPos) / barWidth, 0, 1)
            local newSpeed = math.floor(50 + percent * 450)
            Settings.FlySpeed = newSpeed
            SpeedFill.Size = UDim2.new(percent, 0, 1, 0)
            SpeedSliderBtn.Position = UDim2.new(percent, -10, -0.5, 0)
            SpeedLabel.Text = "✈️ FLIGHT SPEED: " .. Settings.FlySpeed
            SpeedValue.Text = Settings.FlySpeed
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingSlider = false
        end
    end)
    
    -- Drag to Move Window
    local draggingWindow = false
    local dragStartPos
    local windowStartPos
    
    Header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingWindow = true
            dragStartPos = input.Position
            windowStartPos = MainFrame.Position
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if draggingWindow and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStartPos
            MainFrame.Position = UDim2.new(windowStartPos.X.Scale, windowStartPos.X.Offset + delta.X, windowStartPos.Y.Scale, windowStartPos.Y.Offset + delta.Y)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingWindow = false
        end
    end)
    
    -- Update status loop
    coroutine.wrap(function()
        while ScreenGui.Parent do
            if Settings.Enabled and Settings.CurrentTarget then
                TargetText.Text = "🎯 TARGET: " .. Settings.CurrentTarget.Name
            else
                TargetText.Text = "🎯 TARGET: -"
            end
            
            local fruits = ScanForFruits()
            FruitCounter.Text = "🍎 " .. #fruits
            
            wait(0.3)
        end
    end)()
    
    blur.Size = 12
end

-- Initialize
CreateMainGUI()

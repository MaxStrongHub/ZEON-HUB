-- Flying Variables
local FlyEnabled = false
local BodyVelocity = Instance.new("BodyVelocity")
BodyVelocity.MaxForce = Vector3.new(1/0, 1/0, 1/0)

local BodyGyro = Instance.new("BodyGyro")
BodyGyro.MaxTorque = Vector3.new(1/0, 1/0, 1/0)
BodyGyro.P = 10000

local function EnableFly()
    FlyEnabled = true
    BodyVelocity.Parent = RootPart
    BodyGyro.Parent = RootPart
    Humanoid.PlatformStand = true
end

local function DisableFly()
    FlyEnabled = false
    BodyVelocity.Velocity = Vector3.new(0, 0, 0)
    BodyVelocity.Parent = nil
    BodyGyro.Parent = nil
    Humanoid.PlatformStand = false
end

local function FlyTo(position)
    if not FlyEnabled then return false end
    
    local direction = (position - RootPart.Position).unit
    local distance = (RootPart.Position - position).magnitude
    local speed = Settings.FlySpeed
    
    if distance < 5 then
        BodyVelocity.Velocity = Vector3.new(0, 0, 0)
        return true
    end
    
    local velocity = direction * math.min(speed, distance * 1.2)
    BodyVelocity.Velocity = velocity
    
    -- Face target
    BodyGyro.CFrame = CFrame.new(RootPart.Position, position)
    
    -- Auto height adjustment
    local yDiff = position.Y - RootPart.Position.Y
    if math.abs(yDiff) > 3 then
        BodyVelocity.Velocity = BodyVelocity.Velocity + Vector3.new(0, yDiff > 0 and speed * 0.5 or -speed * 0.3, 0)
    end
    
    return false
end


local function RemoveESP(fruitModel)
    if ESPObjects[fruitModel] then
        if ESPObjects[fruitModel].Billboard then ESPObjects[fruitModel].Billboard:Destroy() end
        if ESPObjects[fruitModel].Box then ESPObjects[fruitModel].Box:Destroy() end
        ESPObjects[fruitModel] = nil
    end
end

local function ClearAllESP()
    for fruitModel, data in pairs(ESPObjects) do
        if data.Billboard then data.Billboard:Destroy() end
        if data.Box then data.Box:Destroy() end
    end
    ESPObjects = {}
end

-- Scan Fruits
local function ScanForFruits()
    local fruits = {}
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Handle") and FruitModels[v.Name] then
            local position = v:FindFirstChild("Handle").Position
            local distance = (RootPart.Position - position).magnitude
            local rarity, color = GetFruitRarity(v.Name)
            
            table.insert(fruits, {
                Model = v,
                Position = position,
                Distance = distance,
                Name = v.Name,
                Rarity = rarity,
                Color = color
            })
            
            if Settings.ESPEnabled then
                CreateESP(v, v.Name)
            end
        end
    end
    
    for fruitModel, _ in pairs(ESPObjects) do
        if not fruitModel.Parent or not fruitModel:FindFirstChild("Handle") or not FruitModels[fruitModel.Name] then
            RemoveESP(fruitModel)
        end
    end
    
    table.sort(fruits, function(a, b) return a.Distance < b.Distance end)
    return fruits
end

-- Auto Store
local function AutoStoreFruit(fruitModel)
    if not Settings.AutoStore then return end
    
    local tool = fruitModel:FindFirstChildOfClass("Tool")
    if tool and tool.Parent == fruitModel then
        local remote = ReplicatedStorage:FindFirstChild("Remotes")
        if remote then
            local storeRemote = remote:FindFirstChild("StoreFruit")
            if storeRemote then
                storeRemote:InvokeServer("Store", tool)
                Notify("ZEON HUB", "Stored: " .. fruitModel.Name, 2)
            end
        end
    end
end

-- Collect Fruit
local function CollectFruit(fruitModel)
    local tool = fruitModel:FindFirstChildOfClass("Tool")
    if tool then
        local remote = ReplicatedStorage:FindFirstChild("Remotes")
        if remote then
            local collectRemote = remote:FindFirstChild("CollectFruit")
            if collectRemote then
                local success = collectRemote:InvokeServer("Collect", tool)
                if success ~= false then
                    Notify("🍎 FRUIT FOUND!", fruitModel.Name .. " [" .. (FruitModels[fruitModel.Name] or "Common") .. "]", 3)
                    wait(0.3)
                    AutoStoreFruit(fruitModel)
                    RemoveESP(fruitModel)
                    return true
                end
            end
        end
    end
    return false
end

-- Main Auto Collect Loop
local function AutoCollectLoop()
    while Settings.Enabled do
        local fruits = ScanForFruits()
        
        if #fruits > 0 then
            local target = fruits[1]
            Settings.CurrentTarget = target.Model
            Settings.CurrentTargetName = target.Name
            
            Notify("🎯 TARGET", target.Name .. " [" .. target.Rarity .. "] - " .. math.floor(target.Distance) .. "m", 2)
            
            EnableFly()
            
            local reached = false
            local attempts = 0
            while not reached and Settings.Enabled and target.Model and target.Model.Parent == workspace and attempts < 80 do
                local currentPos = target.Model:FindFirstChild("Handle")
                if currentPos then
                    reached = FlyTo(currentPos.Position)
                else
                    break
                end
                RunService.RenderStepped:Wait()
                attempts = attempts + 1
            end
            
            DisableFly()
            
            if target.Model and target.Model.Parent == workspace then
                CollectFruit(target.Model)
            end
            
            Settings.CurrentTarget = nil
            Settings.CurrentTargetName = nil
            wait(0.5)
        else
            wait(2)
        end
    end
end

-- ESP Update Loop
coroutine.wrap(function()

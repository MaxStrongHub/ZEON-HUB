local function RemoveESP(fruitModel)
    if ESPObjects[fruitModel] then
        if ESPObjects[fruitModel].Billboard then ESPObjects[fruitModel].Billboard:Destroy() end
        if ESPObjects[fruitModel].Box then ESPObjects[fruitModel].Box:Destroy() end
        ESPObjects[fruitModel] = nil
    end
end

local function ClearAllESP()
    for fruitModel, data in pairs(ESPObjects) do
        if data.Billboard then data.Billboard:Destroy() end
        if data.Box then data.Box:Destroy() end
    end
    ESPObjects = {}
end

-- Scan for fruits with ESP
local function ScanForFruits()
    local fruits = {}
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Handle") and table.find(FruitModels, v.Name) then
            local position = v:FindFirstChild("Handle").Position
            local distance = (RootPart.Position - position).magnitude
            local rarity, color = GetFruitRarity(v.Name)
            
            table.insert(fruits, {
                Model = v,
                Position = position,
                Distance = distance,
                Name = v.Name,
                Rarity = rarity,
                Color = color
            })
            
            -- Create ESP if enabled
            if Settings.ESPEnabled then
                CreateESP(v, v.Name, color)
            end
        end
    end
    
    -- Clean up ESP for destroyed fruits
    for fruitModel, _ in pairs(ESPObjects) do
        if not fruitModel.Parent or not fruitModel:FindFirstChild("Handle") or not table.find(FruitModels, fruitModel.Name) then
            RemoveESP(fruitModel)
        end
    end
    
    table.sort(fruits, function(a, b) return a.Distance < b.Distance end)
    return fruits
end

-- Flying Mechanism
local FlyEnabled = false
local BodyVelocity = Instance.new("BodyVelocity")
BodyVelocity.MaxForce = Vector3.new(1/0, 1/0, 1/0)

local function SetupFly()
    BodyVelocity.Parent = RootPart
    BodyVelocity.Velocity = Vector3.new(0, 0, 0)
end

local function FlyTo(position)
    if not FlyEnabled then return end
    local direction = (position - RootPart.Position).unit
    local distance = (position - RootPart.Position).magnitude
    local speed = Settings.FlySpeed
    
    if distance < 8 then
        BodyVelocity.Velocity = Vector3.new(0, 0, 0)
        return true
    end
    
    local velocity = direction * math.min(speed, distance * 1.5)
    BodyVelocity.Velocity = velocity
    
    -- Auto Y adjustment
    local yDiff = position.Y - RootPart.Position.Y
    if yDiff > 5 then
        BodyVelocity.Velocity = BodyVelocity.Velocity + Vector3.new(0, speed * 0.6, 0)
    elseif yDiff < -5 then
        BodyVelocity.Velocity = BodyVelocity.Velocity - Vector3.new(0, speed * 0.4, 0)
    end
    
    return false
end

-- Auto Store
local function AutoStoreFruit(fruitModel)
    if not Settings.AutoStore then return end
    
    local tool = fruitModel:FindFirstChildOfClass("Tool")
    if tool and tool.Parent == fruitModel then
        local args = {
            [1] = "Store",
            [2] = tool
        }
        local remote = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
        if remote then
            local storeRemote = remote:FindFirstChild("StoreFruit")
            if storeRemote then
                storeRemote:InvokeServer(unpack(args))
                wait(0.3)
            end
        end
    end
end

-- Main Loop
local function FindAndCollect()
    while Settings.Enabled do
        local fruits = ScanForFruits()
        if #fruits > 0 then
            local target = fruits[1]
            Settings.CurrentTarget = target.Model
            
            -- Fly to fruit
            FlyEnabled = true
            SetupFly()
            
            local reached = false
            local timeout = 0
            while not reached and Settings.Enabled and target.Model and target.Model.Parent == workspace and timeout < 30 do
                local currentPos = target.Model:FindFirstChild("Handle")
                if currentPos then
                    reached = FlyTo(currentPos.Position)
                else
                    break
                end
                RunService.RenderStepped:Wait()
                timeout = timeout + 0.1
            end
            
            FlyEnabled = false
            BodyVelocity.Velocity = Vector3.new(0, 0, 0)
            
            -- Collect fruit
            if target.Model and target.Model.Parent == workspace then
                local tool = target.Model:FindFirstChildOfClass("Tool")
                if tool then
                    local remote = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
                    if remote then
                        local collectRemote = remote:FindFirstChild("CollectFruit")
                        if collectRemote then
                            local args = {
                                [1] = "Collect",
                                [2] = tool
                            }
                            collectRemote:InvokeServer(unpack(args))
                            wait(0.3)
                            AutoStoreFruit(target.Model)
                        end
                    end
                end
                RemoveESP(target.Model)
            end
            
            Settings.CurrentTarget = nil
            wait(1)
        else
            wait(2)
        end
    end
end

-- ESP Update Loop
local function ESPUpdateLoop()
    while true do
        if Settings.ESPEnabled then
            for fruitModel, data in pairs(ESPObjects) do
                if data.Box and data.Handle and data.Handle.Parent then
                    data.Box.Size = data.Handle.Size + Vector3.new(2, 2, 2)
                end
            end
        end
        wait(0.1)
    end
end

coroutine.wrap(ESPUpdateLoop)()


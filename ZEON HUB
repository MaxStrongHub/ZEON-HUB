local function GetFruitRarity(fruitName)
    local common = {"ROCKET", "SPIN", "BLADE", "SPRING", "BOMB", "SMOKE", "SPIKE"}
    local uncommon = {"FLAME", "ICE", "SAND", "DARK", "EAGLE", "DIAMOND", "LIGHT", "RUBBER", "GHOST"}
    local rare = {"MAGMA", "QUAKER", "BUDDHA", "LOVE", "CREATION", "SPIDER", "SOUND", "PHOENIX"}
    local legendary = {"PORTAL", "LIGHTNING", "PAIN", "BLIZZARD", "GRAVITY", "MAMMOTH", "TREX", "DOUGH"}
    local mythical = {"SHADOW", "VENOM", "GAS", "SPIRIT", "TIGER", "YETI", "KITSUNE"}
    
    if table.find(common, fruitName) then return "Common", FruitColors.Common
    elseif table.find(uncommon, fruitName) then return "Uncommon", FruitColors.Uncommon
    elseif table.find(rare, fruitName) then return "Rare", FruitColors.Rare
    elseif table.find(legendary, fruitName) then return "Legendary", FruitColors.Legendary
    elseif table.find(mythical, fruitName) then return "Mythical", FruitColors.Mythical
    else return "Unknown", Color3.fromRGB(255, 255, 255) end
end


-- Slider Function
local draggingSlider = false
SpeedSliderBtn.MouseButton1Down:Connect(function()
    draggingSlider = true
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
        local barPos = SpeedSliderBar.AbsolutePosition.X
        local barWidth = SpeedSliderBar.AbsoluteSize.X
        local mouseX = input.Position.X
        local percent = math.clamp((mouseX - barPos) / barWidth, 0, 1)
        local newSpeed = math.floor(80 + percent * 420)
        Settings.FlySpeed = newSpeed
        SpeedFill.Size = UDim2.new(percent, 0, 1, 0)
        SpeedSliderBtn.Position = UDim2.new(percent, -8, -0.5, 0)
        SpeedLabel.Text = "✈️ FLY SPEED: " .. Settings.FlySpeed
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = false
    end
end)

-- Update status loop
coroutine.wrap(function()
    while ScreenGui.Parent do
        if Settings.Enabled and Settings.CurrentTarget then
            TargetStatus.Text = "🎯 TARGET: " .. Settings.CurrentTarget.Name
        else
            TargetStatus.Text = "🎯 TARGET: -"
        end
        
        local fruits = ScanForFruits()
        if #fruits > 0 and Settings.Enabled and not Settings.CurrentTarget then
            local nearest = fruits[1]
            TargetStatus.Text = "🎯 NEAREST: " .. nearest.Name .. " [" .. math.floor(nearest.Distance) .. "m]"
        end
        
        wait(0.5)
    end
end)()


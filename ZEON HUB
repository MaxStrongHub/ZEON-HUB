-- Update Profile
local function UpdateProfile()
    local stats = GetPlayerStats()
    UsernameText.Text = stats.DisplayName .. " [" .. stats.Username .. "]"
    LevelText.Text = "Level: " .. stats.Level
    BountyText.Text = "Bounty: " .. stats.Bounty
    RaceText.Text = "Race: " .. stats.Race
    MeleeText.Text = "👊 Melee: " .. stats.Melee
    FruitText.Text = "🍎 Fruit: " .. stats.Fruit
    GunText.Text = "🔫 Gun: " .. stats.Gun
    SwordText.Text = "⚔️ Sword: " .. stats.Sword
    
    -- Load avatar
    local thumbnail = Players:GetUserThumbnailAsync(LocalPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
    AvatarImage.Image = thumbnail
end

-- Tab Switching
local function SwitchToProfile()
    ProfilePage.Visible = true
    FarmPage.Visible = false
    ProfileTab.BackgroundColor3 = Color3.fromRGB(0, 50, 0)

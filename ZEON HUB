-- Slider
local draggingSlider = false
SpeedSlider.MouseButton1Down:Connect(function()
    draggingSlider = true
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
        local barPos = SpeedBar.AbsolutePosition.X
        local barWidth = SpeedBar.AbsoluteSize.X
        local mouseX = input.Position.X
        local percent = math.clamp((mouseX - barPos) / barWidth, 0, 1)
        local newSpeed = math.floor(80 + percent * 420)
        Settings.FlySpeed = newSpeed
        SpeedFill.Size = UDim2.new(percent, 0, 1, 0)
        SpeedSlider.Position = UDim2.new(percent, -7, -0.5, 0)
        SpeedTitle.Text = "FLIGHT SPEED: " .. Settings.FlySpeed
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = false
    end
end)


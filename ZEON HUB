-- Animation Function
local function AnimateButton(button)
    local originalSize = button.Size
    local tween = TweenService:Create(button, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset - 2, originalSize.Y.Scale, originalSize.Y.Offset - 2)})
    tween:Play()
    tween.Completed:Connect(function()
        local tween2 = TweenService:Create(button, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = originalSize})
        tween2:Play()
    end)
end

-- Tab Switching
local function SwitchToProfile()
    ProfilePage.Visible = true
    FarmPage.Visible = false
    ProfileBtn.BackgroundColor3 = Color3.fromRGB(60, 45, 100)
    ProfileBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    ProfileBtn.Font = Enum.Font.GothamBold
    FarmBtn.BackgroundColor3 = Color3.fromRGB(45, 35, 80)
    FarmBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    FarmBtn.Font = Enum.Font.Gotham
end

local function SwitchToFarm()
    ProfilePage.Visible = false
    FarmPage.Visible = true
    FarmBtn.BackgroundColor3 = Color3.fromRGB(60, 45, 100)
    FarmBtn.TextColor3 = Color3.fromRGB(255, 255, 255)

-- Get Player Stats
local function GetPlayerStats()
    local stats = {
        Username = LocalPlayer.Name,
        DisplayName = LocalPlayer.DisplayName,
        UserId = LocalPlayer.UserId,
        Level = 0,
        Melee = "None",
        Fruit = "None",
        Gun = "None",
        Sword = "None"
    }
    
    -- Get Thumbnail
    local thumbnail = Players:GetUserThumbnailAsync(LocalPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
    
    -- Get stats from game
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats then
        local level = leaderstats:FindFirstChild("Level")
        if level then stats.Level = level.Value end
    end
    
    -- Get equipped items
    local equipment = LocalPlayer:FindFirstChild("Data") and LocalPlayer.Data:FindFirstChild("Equipment")
    if equipment then
        stats.Melee = equipment:FindFirstChild("Melee") and equipment.Melee.Value or "None"
        stats.Fruit = equipment:FindFirstChild("Fruit") and equipment.Fruit.Value or "None"
        stats.Gun = equipment:FindFirstChild("Gun") and equipment.Gun.Value or "None"
        stats.Sword = equipment:FindFirstChild("Sword") and equipment.Sword.Value or "None"
    end
    
    return stats, thumbnail
end


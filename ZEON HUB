-- Get Player Blox Fruit Stats
local function GetPlayerStats()
    local stats = {
        Username = LocalPlayer.Name,
        DisplayName = LocalPlayer.DisplayName,
        Level = 0,
        Melee = "None",
        Fruit = "None",
        Gun = "None",
        Sword = "None",
        Bounty = 0,
        Race = "Human"
    }
    
    -- Get level
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats then
        local level = leaderstats:FindFirstChild("Level")
        if level then stats.Level = level.Value end
        local bounty = leaderstats:FindFirstChild("Bounty")
        if bounty then stats.Bounty = bounty.Value end
    end
    
    -- Get equipped items from Blox Fruits data
    local data = LocalPlayer:FindFirstChild("Data")
    if data then
        local equipment = data:FindFirstChild("Equipment")
        if equipment then
            local melee = equipment:FindFirstChild("Melee")
            if melee and melee.Value ~= "" then stats.Melee = melee.Value end
            
            local fruit = equipment:FindFirstChild("Fruit")
            if fruit and fruit.Value ~= "" then stats.Fruit = fruit.Value end
            
            local gun = equipment:FindFirstChild("Gun")
            if gun and gun.Value ~= "" then stats.Gun = gun.Value end
            
            local sword = equipment:FindFirstChild("Sword")
            if sword and sword.Value ~= "" then stats.Sword = sword.Value end
        end
        
        local race = data:FindFirstChild("Race")
        if race then stats.Race = race.Value end
    end
    
    -- Alternative detection using stats
    local statsFolder = LocalPlayer:FindFirstChild("Stats")
    if statsFolder then
        local meleeStat = statsFolder:FindFirstChild("Melee")
        if meleeStat and meleeStat.Value > 0 and stats.Melee == "None" then stats.Melee = "Equipped" end
    end
    
    return stats
end

